{
  "name": "Gam3a Store",
  "short_name": "Gam3a Store",
  "description": "تطوير شهاب طارق صلاح طالب بكلية التجارة جامعة الزقازيق",
  "start_url": "/",
  "id": "622006",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "dir": "rtl",
  "lang": "ar",
  "scope": "/",
  "categories": ["shopping", "business", "social", "education"],
  "display_override": ["tabbed", "window-controls-overlay", "minimal-ui"],
  "icons": [
    {
      "src": "/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "سياسة الخصوصية",
      "url": "/privacy.html",
      "icons": [{"src": "/icon-192x192.png", "sizes": "192x192"}]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-mobile.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile View"
    },
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop View"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/*": [".txt"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+gam3a",
      "url": "/?type=%s"
    }
  ],
  "note_taking": {
    "new_note_url": "/index.html"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    {"origin": "https://gam3a-store.vercel.app"}
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "share_target": {
    "action": "/?share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "e5814b2d-e97c-47fc-9104-58a369bd6543"
}